# =============================================================
#  TripOye VisaOS — Environment configuration
#  Copy this file to .env and fill in. NEVER commit .env to git.
# =============================================================

# ---------- App ----------
NODE_ENV=production
PORT=3000
APP_URL=https://yourdomain.com
APP_NAME=TripOye VisaOS

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace-with-a-random-64-char-hex-string

# ---------- Database (Hostinger MySQL) ----------
DB_HOST=localhost
DB_PORT=3306
DB_NAME=u123456_tripoye
DB_USER=u123456_tripoye
DB_PASS=change-this-password

# ---------- OpenAI (Noor AI assistant + eligibility scorer) ----------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_STT_MODEL=whisper-1

# ---------- ElevenLabs (voice replies) ----------
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL

# ---------- WhatsApp Cloud API (Meta) ----------
WA_PHONE_NUMBER_ID=
WA_BUSINESS_TOKEN=
WA_VERIFY_TOKEN=tripoye_verify_xyz

# ---------- OCR — Google Document AI (recommended for passport MRZ) ----------
GCP_PROJECT_ID=
GCP_PROCESSOR_ID=
GCP_KEY_JSON_PATH=./config/gcp-key.json

# ---------- Payments — Razorpay (India) ----------
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ---------- Payments — Stripe (international) ----------
STRIPE_PUB_KEY=
STRIPE_SECRET=

# ---------- SMTP (transactional email) ----------
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=587
SMTP_USER=noreply@yourdomain.com
SMTP_PASS=
SMTP_FROM_EMAIL=noreply@yourdomain.com
SMTP_FROM_NAME=TripOye VisaOS

# ---------- Branding / support ----------
SUPPORT_WHATSAPP=+919999999999
SUPPORT_EMAIL=help@yourdomain.com
SUPPORT_PHONE=+91 80 4000 4000

# ---------- Feature flags (true/false) ----------
FEATURE_AI_CHAT=true
FEATURE_WHATSAPP=false
FEATURE_VOICE=true
FEATURE_LIVE_OCR=false
FEATURE_RAZORPAY=false
FEATURE_STRIPE=false
